{\n  "groups": {\n    "Group1": {\n      "name": "Breakouts with Force Gradient F=M×A",\n      "description": "This group focuses on identifying breakout events using the force gradient formula, where the force is defined as F = M × A (mass multiplied by acceleration). The aim is to spot potential upward or downward movements in the market when price breaks through key resistance or support levels.",\n      "indicators": [\n        {\n          "name": "Force Gradient",\n          "calculation": "F = M × A",\n          "usage": "Used to identify breakouts when price moves beyond a specified range with significant force."
        }\n      ]\n    },\n    "Group2": {\n      "name": "Reversal Patterns with OBV",\n      "description": "This group aims to recognize reversal patterns in market trends, leveraging the On-Balance Volume (OBV) indicator to confirm potential reversals by analyzing volume flow related to price declines and advances.",\n      "indicators": [\n        {\n          "name": "On-Balance Volume (OBV)",\n          "usage": "Utilized to track volume trends and confirm reversal signals when OBV diverges from price movement."
        }\n      ]\n    },\n    "Group3": {\n      "name": "Volume Anomalies with VWAP",\n      "description": "This group studies volume anomalies by utilizing the Volume Weighted Average Price (VWAP). The focus is on finding instances where current volume significantly deviates from historical averages, possibly signaling an upcoming trend or reversal.",\n      "indicators": [\n        {\n          "name": "Volume Weighted Average Price (VWAP)",\n          "usage": "Acts as a mean for assessing price based on volume. Anomalies occur when trading volume strays from the expected range."
        }\n      ]\n    },\n    "Group4": {\n      "name": "Multi-Timeframe Rejections with Volume-Weighted ATR",\n      "description": "This group utilizes a multi-timeframe approach to detect price rejections, incorporating the Volume-Weighted Average True Range (ATR) to measure volatility and enhance decision-making during potential rejection points across different timeframes.",\n      "indicators": [\n        {\n          "name": "Volume-Weighted Average True Range (ATR)",\n          "usage": "Allows for a better appraisal of market volatility. Recognizes rejection points by assessing price movements across multiple timeframes."
